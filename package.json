{
  "name": "@its-not-rocket-science/ananke-historical-battles",
  "version": "0.1.0",
  "type": "module",
  "description": "Historical battle validation scenarios for @its-not-rocket-science/ananke",
  "license": "MIT",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": ["dist", "scenarios"],
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build": "tsc",
    "test": "vitest run",
    "validate": "node dist/src/tools/run-battles.js",
    "run:battles": "node dist/src/tools/run-battles.js",
    "prepublishOnly": "npm run build && npm run test"
  },
  "dependencies": {
    "@its-not-rocket-science/ananke": "^0.1.4"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.5.4",
    "vitest": "^2.1.8"
  }
}
